direction: down

# ═══════════════════════════════════════════════════════════════
# DAG 1: LOCAL DEVELOPER SETUP
# ═══════════════════════════════════════════════════════════════

local_setup: Local Developer Setup {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  direction: down

  download: Download agent-secrets binary {
    shape: rectangle
    style.fill: "#BBDEFB"
  }

  scaffold: "~/.agent-secrets/ scaffolded automatically" {
    shape: rectangle
    style.fill: "#E8F5E9"
  }

  edit_def: "Edit secrets.def" {
    shape: rectangle
    style.fill: "#BBDEFB"
  }

  edit_secrets: "Set values in .secrets" {
    shape: rectangle
    style.fill: "#FFECB3"
  }

  ready: Ready {
    shape: rectangle
    style.fill: "#C8E6C9"
  }

  download -> scaffold
  scaffold -> edit_def
  edit_def -> edit_secrets
  edit_secrets -> ready
  edit_secrets -> edit_def: add or remove entries {style.stroke-dash: 4}
}

# ═══════════════════════════════════════════════════════════════
# DAG 2: PUSH TO REMOTE
# ═══════════════════════════════════════════════════════════════

push_flow: Push to Remote {
  style.fill: "#F3E5F5"
  style.stroke: "#6A1B9A"
  style.stroke-width: 2
  direction: down

  push_cmd: "agent-secrets push user@host" {
    shape: rectangle
    style.fill: "#E1BEE7"
  }

  ssh_auth: SSH Auth {
    shape: diamond
    style.fill: "#FCE4EC"
  }

  cli_check: CLI installed on remote? {
    shape: diamond
    style.fill: "#FFF9C4"
  }

  ask_permission: Ask user permission to install {
    shape: rectangle
    style.fill: "#FFE0B2"
  }

  user_approves: User approves? {
    shape: diamond
    style.fill: "#FFF9C4"
  }

  install_cli: Install CLI into PATH {
    shape: rectangle
    style.fill: "#E8F5E9"
  }

  abort: Abort {
    shape: rectangle
    style.fill: "#FFCDD2"
  }

  upload: Upload secrets file {
    shape: rectangle
    style.fill: "#E1BEE7"
  }

  done: Remote ready {
    shape: rectangle
    style.fill: "#C8E6C9"
  }

  push_cmd -> ssh_auth
  ssh_auth -> cli_check: authenticated
  cli_check -> upload: yes
  cli_check -> ask_permission: no
  ask_permission -> user_approves
  user_approves -> install_cli: approved
  user_approves -> abort: denied {style.stroke-dash: 4}
  install_cli -> upload
  upload -> done
}

# ═══════════════════════════════════════════════════════════════
# DAG 3: AGENT QUERIES SECRETS
# ═══════════════════════════════════════════════════════════════

agent_flow: Agent Queries Secrets {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  direction: down

  list_cmd: "agent-secrets list" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }

  auto_sync: Auto-sync from secrets.def + .secrets {
    shape: rectangle
    style.fill: "#DCEDC8"
  }

  pick: Agent picks relevant secret {
    shape: rectangle
    style.fill: "#C8E6C9"
  }

  query_cmd: "agent-secrets query <desc>" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }

  fts: FTS5 search on descriptions {
    shape: rectangle
    style.fill: "#DCEDC8"
  }

  result: Secret value returned {
    shape: rectangle
    style.fill: "#A5D6A7"
  }

  list_cmd -> auto_sync
  auto_sync -> pick
  pick -> query_cmd
  query_cmd -> fts
  fts -> result
}
