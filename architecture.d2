direction: right

source: "~/.agent-secrets/" {
  direction: down

  secrets_def: secrets.def {
    shape: page
    content: |md
      ```yaml
      API_KEY: "OpenAI API key"
      DB_PASS: "Prod DB password"
      ```
    |
  }

  dot_secrets: .secrets {
    shape: page
    style.stroke-dash: 5
    content: |md
      ```env
      API_KEY=sk-abc123
      DB_PASS=hunter2
      ```
    |
  }
}

cli: "agent-secrets (Go)" {
  grid-rows: 2
  grid-columns: 2

  list: list {shape: hexagon}
  query: "query <desc>" {shape: hexagon}
  push: "push user@host" {shape: hexagon}
}

db: Secrets DB {
  style.stroke-dash: 5
  schema: SQLite + FTS5 {
    shape: sql_table
    uuid: TEXT {constraint: PK}
    variable_name: TEXT
    description: TEXT {constraint: "FTS index"}
    secret_value: TEXT
  }
}

remote: Remote Server {
  direction: down
  ssh: SSH Auth {shape: diamond}
  remote_cli: agent-secrets {shape: hexagon}
  remote_db: Secrets DB {shape: cylinder}

  ssh -> remote_cli: installs
  ssh -> remote_db: uploads
  remote_cli -> remote_db: query
}

agent: AI Agent {shape: person}

# ── Flow ──────────────────────────────────────────────────────

source -> cli: reads on every command
cli -> db: auto-syncs on every command
db -> remote: push via SSH
agent -> db: query / list

# ── Ordering ──────────────────────────────────────────────────

source -> cli: "" {style.opacity: 0}
cli -> db: "" {style.opacity: 0}
db -> remote: "" {style.opacity: 0}
remote -> agent: "" {style.opacity: 0}
